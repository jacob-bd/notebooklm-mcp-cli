# Syncthing ignore: machine-local artifacts
# Canonical template: C010_standards/templates/.stignore.template
# Policy: C010_standards/protocols/syncthing_stignore_policy.md
# IMPORTANT: This file MUST be tracked in git. Do NOT add .stignore to .gitignore.

# Claude Code local projections (generated by sync_to_claude.py or git checkout)
.claude/commands/
.claude/skills/
.claude/settings.local.json

# Third-party agent skills (installed via npx skills add, machine-local)
.agents/
.continue/
skills-lock.json

# Virtual environments (platform-specific binaries)
.venv/

# macOS metadata (contain Windows-reserved characters)
.DS_Store
._*
Icon*

# Windows metadata
Thumbs.db
Desktop.ini

# Python bytecode (platform-specific)
__pycache__/
*.pyc

# Pytest temp directories (often created with restrictive ACLs)
.pytest_cache/
.pytest_tmp*
.tmp_pytest_*
pytest_tmp_*

# Build and pip temp directories (locked files break Windows sync)
.tmp/
.tmp_bugscan_temp/
**/pip-build-tracker-*
**/pip-ephem-wheel-cache-*
**/pip-install-*
**/pip-target-*
**/pip-unpack-*

# Generic temp files (Python tempfile module, pytest, etc.)
**/tmp?*

# Repo-specific patterns (preserved from previous .stignore)
# Virtual environments are platform-specific (Windows Lib/ vs macOS lib/, different binaries)
# macOS custom folder icon — contains
 which is a Windows-reserved character
